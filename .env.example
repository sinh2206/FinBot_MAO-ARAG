# Local planner/executor settings.
ENABLE_LOCAL_PLANNER=true
ENABLE_LOCAL_EXECUTOR=true
ENABLE_RERANKER=true
LOCAL_FILES_ONLY=true
LOAD_IN_4BIT=true

# Planner: Phi-4-mini-instruct.
PLANNER_PROVIDER=local
PLANNER_MODEL_NAME=models/phi
PHI_MODEL_NAME=models/phi

# Primary executor: Qwen.
EXECUTOR_PROVIDER=local
EXECUTOR_MODEL_NAME=models/qwen
QWEN_MODEL_NAME=models/qwen

# Fallback executor: Gemini only when Qwen returns empty / KHÔNG TÌM THẤY.
ENABLE_GEMINI_API=true
ENABLE_GEMINI_FALLBACK_EXECUTOR=true
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_FALLBACK_MAX_OUTPUT_TOKENS=64
GEMINI_FALLBACK_THINKING_BUDGET=0
GEMINI_FALLBACK_CONTEXT_CHARS=900
GEMINI_FALLBACK_MAX_SNIPPETS=2
GEMINI_FALLBACK_MAX_SNIPPET_CHARS=220

# Local folders after running scripts/download_models.py.
EMBEDDING_MODEL_NAME=models/embedder
RERANKER_MODEL_NAME=models/cross_encoder

# Hugging Face repo IDs used by the downloader:
# EXECUTOR_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
# EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2

# Retrieval mode: hybrid, dense_only, sparse_only.
RAG_RETRIEVAL_MODE=hybrid
RAG_DENSE_WEIGHT=0.65
RAG_SPARSE_WEIGHT=0.35
RAG_TOP_K=10
RAG_EXECUTOR_TOP_K=5

RAG_DOCUMENT_PATH=data/chunks/chunks.json
RAG_INDEX_PATH=data/index
