# Local model settings. No API key is required for inference after models are downloaded.
ENABLE_LOCAL_PLANNER=false
ENABLE_LOCAL_EXECUTOR=false
ENABLE_RERANKER=false
LOCAL_FILES_ONLY=true
LOAD_IN_4BIT=false

# Hidden Gemini API setup. Keep disabled while comparing/evaluating local models.
ENABLE_GEMINI_API=false
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-flash

# Use Hugging Face repo IDs before download, or local folders after download.
QWEN_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
EXECUTOR_MODEL_NAME=LiquidAI/LFM2-1.2B-RAG
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2

# After running scripts/download_models.py, switch to:
# QWEN_MODEL_NAME=models/qwen
# EXECUTOR_MODEL_NAME=models/lfm2_rag
# EMBEDDING_MODEL_NAME=models/embedder
# RERANKER_MODEL_NAME=models/cross_encoder

# Retrieval mode: hybrid, dense_only, sparse_only.
RAG_RETRIEVAL_MODE=sparse_only
RAG_DENSE_WEIGHT=0.65
RAG_SPARSE_WEIGHT=0.35
RAG_TOP_K=10
RAG_EXECUTOR_TOP_K=5

RAG_DOCUMENT_PATH=data/chunks/chunks.json
RAG_INDEX_PATH=data/index
